# Server
USER_API_PORT=4001

# MongoDB (shared animeApp DB)
MONGODB_URI=

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Redis (optional, for chat + profile caching)
USER_API_REDIS_CONN_URL=

# CORS — comma-separated list of allowed origins
# Example: https://yourdomain.com,https://www.yourdomain.com
USER_API_CORS_ALLOWED_ORIGINS=

# Rate Limiting
USER_API_WINDOW_MS=
USER_API_MAX_REQS=

# Hostname (enables rate limiting when set)
USER_API_HOSTNAME=

# Deployment environment: nodejs | docker | vercel | cloudflare-workers | render
USER_API_DEPLOYMENT_ENV=nodejs

# Cache control (CDN)
USER_API_S_MAXAGE=60
USER_API_STALE_WHILE_REVALIDATE=30

NODE_ENV=development
